{
  "name": "signatura_e_vault",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:reset": "rm -rf .next && next dev",
    "dev:lan": "next dev -H 0.0.0.0 -p 3000",
    "dev:lan:reset": "rm -rf .next && next dev -H 0.0.0.0 -p 3000",
    "dev:lan:https": "next dev --experimental-https -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --import ./test/harness/register-loader.mjs --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test \"test/**/*.test.?(m)js\"",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "demo:seed-signatura": "node scripts/demo-seed-signatura.mjs",
    "demo:presentation-token": "node scripts/demo-presentation-token.mjs",
    "check:hoa-signatura-dev": "node scripts/check-hoa-signatura-dev.mjs",
    "migrate:legacy-issuers": "node scripts/migrate-legacy-issuer-json-to-prisma.mjs",
    "sandbox:reset": "node scripts/reset-signatura-sandbox.mjs",
    "reset:dev": "node ../havenxsig/scripts/reset-dev-environment.mjs",
    "reset:dbjson": "node -e \"require('fs').rmSync('data/db.json', { force: true }); console.log('Removed data/db.json')\""
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^1.17.0",
    "next": "^16.2.6",
    "onnxruntime-node": "^1.26.0",
    "paddleocr": "^1.1.1",
    "pdf2image": "^1.2.3",
    "pdf2pic": "^3.2.0",
    "pg": "^8.21.0",
    "postcss": "^8.5.15",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "25.9.0",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^4"
  }
}
