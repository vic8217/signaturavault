generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String               @id
  signaturaId       String               @unique @map("signatura_id")
  email             String?              @unique
  name              String?
  emailLookupHash   String?              @map("email_lookup_hash")
  mobileLookupHash  String?              @map("mobile_lookup_hash")
  accountStatus     String               @default("active") @map("account_status")
  trustLevel        Int                  @default(1) @map("trust_level")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  authChallenges    AuthChallenge[]
  consents          Consent[]
  recoveryCodes     RecoveryCode[]
  securityEventLogs SecurityEventLog[]
  signaturaSessions SignaturaSession[]
  appLinks          SignaturaAppLink[]
  trustedDevices              TrustedDevice[]
  credentials                 WebAuthnCredential[]
  trustedDeviceLoginChallenges TrustedDeviceLoginChallenge[]
  accountRecoveryRequests      AccountRecoveryRequest[]
  adminSetupTokens            AdminSetupToken[]
  memberships                 Membership[]
  invitedMemberships          Membership[] @relation("MembershipInviter")

  @@index([emailLookupHash])
  @@index([mobileLookupHash])
  @@map("users")
}

model AdminSetupToken {
  id           String    @id @default(cuid())
  tokenHash    String    @unique @map("token_hash")
  userId       String    @map("user_id")
  purpose      String    @default("ADMIN_PASSKEY_SETUP")
  status       String    @default("ACTIVE")
  expiresAt    DateTime  @map("expires_at")
  usedAt       DateTime? @map("used_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  createdById  String?   @map("created_by_id")
  userAgent    String?   @map("user_agent")
  ipHash       String?   @map("ip_hash")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([expiresAt])
  @@index([purpose])
  @@map("admin_setup_tokens")
}

model AccountRecoveryRequest {
  id               String    @id @default(cuid())
  userId           String?   @map("user_id")
  signaturaId      String?   @map("signatura_id")
  emailLookupHash  String?   @map("email_lookup_hash")
  mobileLookupHash String?   @map("mobile_lookup_hash")
  status           String    @default("PENDING")
  cooldownUntil    DateTime? @map("cooldown_until")
  livenessStatus   String?   @map("liveness_status")
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([signaturaId])
  @@index([emailLookupHash])
  @@index([mobileLookupHash])
  @@index([status])
  @@index([cooldownUntil])
  @@map("account_recovery_requests")
}

model TrustedDeviceLoginChallenge {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  shortCode             String    @map("short_code")
  browserSecretHash     String    @map("browser_secret_hash")
  nonce                 String
  clientId              String?   @map("client_id")
  sourceApp             String?   @map("source_app")
  requesterOrigin       String?   @map("requester_origin")
  returnUrl             String?   @map("return_url")
  expectedSignaturaId   String?   @map("expected_signatura_id")
  rolePrefix            String?   @map("role_prefix")
  state                 String?
  requestedAssuranceLevel String?   @map("requested_assurance_level")
  status                String    @default("PENDING")
  approvalTokenHash     String?   @map("approval_token_hash")
  approvingDeviceId     String?   @map("approving_device_id")
  approvingCredentialId String?   @map("approving_credential_id")
  browserUserAgent      String?   @map("browser_user_agent")
  nextPath              String?   @map("next_path")
  approvedAt            DateTime? @map("approved_at")
  consumedAt            DateTime? @map("consumed_at")
  expiresAt             DateTime  @map("expires_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([shortCode, status])
  @@index([userId, status])
  @@index([clientId, status])
  @@index([sourceApp, status])
  @@index([expectedSignaturaId])
  @@index([expiresAt])
  @@map("trusted_device_login_challenges")
}

model WebAuthnCredential {
  id           String    @id
  userId       String    @map("user_id")
  credentialId String    @unique @map("credential_id")
  publicKey    Bytes     @map("public_key")
  counter      Int       @default(0)
  transports   String[]  @default([])
  deviceName   String?   @map("device_name")
  userAgent    String?   @map("user_agent")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastUsedAt   DateTime? @map("last_used_at")
  isTrusted    Boolean   @default(true) @map("is_trusted")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("webauthn_credentials")
}

model TrustedDevice {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  credentialId String?   @map("credential_id")
  deviceName   String?   @map("device_name")
  userAgent    String?   @map("user_agent")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastUsedAt   DateTime? @map("last_used_at")
  isTrusted    Boolean   @default(true) @map("is_trusted")
  removedAt    DateTime? @map("removed_at")
  deviceHash   String    @unique @map("device_hash")
  status       String    @default("active")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([credentialId])
  @@map("trusted_devices")
}

model AuthChallenge {
  id                 String    @id
  userId             String?   @map("user_id")
  issuerInvitationId String?   @map("issuer_invitation_id")
  type               String
  challenge          String    @unique
  deviceName         String?   @map("device_name")
  userAgent          String?   @map("user_agent")
  expiresAt          DateTime  @map("expires_at")
  usedAt             DateTime? @map("used_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  user               User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([issuerInvitationId])
  @@index([type])
  @@map("auth_challenges")
}

model RecoveryCode {
  id         String    @id
  userId     String    @map("user_id")
  codeHash   String    @unique @map("code_hash")
  codePrefix String    @map("code_prefix")
  createdAt  DateTime  @default(now()) @map("created_at")
  usedAt     DateTime? @map("used_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("recovery_codes")
}

model SecurityEventLog {
  id        String   @id
  userId    String?  @map("user_id")
  event     String
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  details   Json?
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([event])
  @@map("security_event_logs")
}

model SecurityAuditLog {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  userId    String?  @map("user_id")
  tenantId  String   @map("tenant_id")
  action    String
  result    String
  ipAddress String?  @map("ip_address")
  device    String?
  details   Json?

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@map("security_audit_logs")
}

model PresentationAccessLink {
  id               String                     @id @default(cuid())
  tokenHash        String                     @unique @map("token_hash")
  tokenCipher      String?                    @map("token_cipher")
  tokenPrefix      String                     @map("token_prefix")
  presentationSlug String                     @map("presentation_slug")
  viewerName       String?                    @map("viewer_name")
  viewerEmail      String?                    @map("viewer_email")
  expiresAt        DateTime                   @map("expires_at")
  usedAt           DateTime?                  @map("used_at")
  maxViews         Int?                       @map("max_views")
  viewCount        Int                        @default(0) @map("view_count")
  isRevoked        Boolean                    @default(false) @map("is_revoked")
  createdAt        DateTime                   @default(now()) @map("created_at")
  updatedAt        DateTime                   @updatedAt @map("updated_at")
  views            PresentationAccessView[]

  @@index([presentationSlug])
  @@index([expiresAt])
  @@index([isRevoked])
  @@map("presentation_access_links")
}

model PresentationAccessView {
  id               String                 @id @default(cuid())
  tokenId          String                 @map("token_id")
  presentationSlug String                 @map("presentation_slug")
  viewedAt         DateTime               @default(now()) @map("viewed_at")
  ipAddress        String?                @map("ip_address")
  userAgent        String?                @map("user_agent")
  token            PresentationAccessLink @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@index([tokenId])
  @@index([presentationSlug])
  @@index([viewedAt])
  @@map("presentation_access_views")
}

model Tenant {
  id                String   @id
  name              String
  externalReference String?  @map("external_reference")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("tenants")
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  type        String
  externalRef String?      @map("external_ref")
  status      String       @default("ACTIVE")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  memberships Membership[]
  roles       Role[]

  @@index([type, status])
  @@index([externalRef])
  @@map("organizations")
}

model Application {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  status      String       @default("ACTIVE")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  memberships Membership[]
  roles       Role[]
  permissions Permission[]

  @@index([status])
  @@map("applications")
}

model Membership {
  id             String           @id @default(cuid())
  identityId     String           @map("identity_id")
  organizationId String?          @map("organization_id")
  applicationId  String           @map("application_id")
  status         String           @default("ACTIVE")
  invitedById    String?          @map("invited_by_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  identity       User             @relation(fields: [identityId], references: [id], onDelete: Cascade)
  invitedBy      User?            @relation("MembershipInviter", fields: [invitedById], references: [id], onDelete: SetNull)
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  application    Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  roles          MembershipRole[]

  @@index([identityId, status])
  @@index([organizationId, status])
  @@index([applicationId, status])
  @@unique([identityId, applicationId, organizationId])
  @@map("memberships")
}

model Role {
  id             String           @id @default(cuid())
  applicationId  String           @map("application_id")
  organizationId String?          @map("organization_id")
  code           String
  name           String
  scope          String
  status         String           @default("ACTIVE")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  application    Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships    MembershipRole[]
  permissions    RolePermission[]

  @@index([applicationId, status])
  @@index([organizationId, status])
  @@unique([applicationId, organizationId, code])
  @@map("roles")
}

model MembershipRole {
  id           String     @id @default(cuid())
  membershipId String     @map("membership_id")
  roleId       String     @map("role_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([membershipId, roleId])
  @@index([roleId])
  @@map("membership_roles")
}

model Permission {
  id            String           @id @default(cuid())
  applicationId String           @map("application_id")
  code          String
  description   String?
  status        String           @default("ACTIVE")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  application   Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  roles         RolePermission[]

  @@unique([applicationId, code])
  @@index([status])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model PrivateFieldKeyReference {
  id              String                         @id @default(cuid())
  tenantId        String                         @map("tenant_id")
  hoaId           String?                        @map("hoa_id")
  keyRef          String                         @unique @map("key_ref")
  algorithm       String
  wrappedKey      String                         @map("wrapped_key")
  salt            String
  iv              String
  tag             String
  kdfName         String                         @map("kdf_name")
  kdfParams       Json                           @map("kdf_params")
  unlockProofSalt String                         @map("unlock_proof_salt")
  unlockProofHash String                         @map("unlock_proof_hash")
  version         Int                            @default(1)
  status          String                         @default("active")
  createdByUserId String                         @map("created_by_user_id")
  createdAt       DateTime                       @default(now()) @map("created_at")
  rotatedAt       DateTime?                      @map("rotated_at")
  authorizations  PrivateFieldKeyAuthorization[]
  privateFields   EncryptedPrivateField[]

  @@index([tenantId])
  @@index([hoaId])
  @@index([status])
  @@map("customer_keys")
}

model PrivateFieldKeyAuthorization {
  id                String                   @id @default(cuid())
  tenantId          String                   @map("tenant_id")
  hoaId             String?                  @map("hoa_id")
  keyRef            String                   @map("key_ref")
  userId            String                   @map("user_id")
  credentialId      String?                  @map("credential_id")
  purpose           String
  authorizationHash String                   @unique @map("authorization_hash")
  status            String                   @default("authorized")
  expiresAt         DateTime                 @map("expires_at")
  consumedAt        DateTime?                @map("consumed_at")
  createdAt         DateTime                 @default(now()) @map("created_at")
  keyReference      PrivateFieldKeyReference @relation(fields: [keyRef], references: [keyRef], onDelete: Cascade)

  @@index([tenantId])
  @@index([hoaId])
  @@index([keyRef])
  @@index([userId])
  @@index([expiresAt])
  @@map("customer_key_unlocks")
}

model EncryptedPrivateField {
  id           String                   @id @default(cuid())
  tenantId     String                   @map("tenant_id")
  hoaId        String?                  @map("hoa_id")
  ownerUserId  String?                  @map("owner_user_id")
  recordType   String                   @map("record_type")
  recordId     String                   @map("record_id")
  fieldKey     String                   @map("field_key")
  keyRef       String                   @map("key_ref")
  algorithm    String
  iv           String
  tag          String
  ciphertext   String
  aad          String?
  version      Int                      @default(1)
  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @updatedAt @map("updated_at")
  keyReference PrivateFieldKeyReference @relation(fields: [keyRef], references: [keyRef])

  @@unique([tenantId, recordType, recordId, fieldKey])
  @@index([tenantId])
  @@index([hoaId])
  @@index([ownerUserId])
  @@index([keyRef])
  @@map("encrypted_private_fields")
}

model Issuer {
  id                 String    @id
  tenantId           String    @map("tenant_id")
  name               String
  contactEmail       String?   @map("contact_email")
  type               String?
  address            String?
  registrationNumber String?   @map("registration_number")
  registrationDate   DateTime? @map("registration_date")
  status             String    @default("active")
  acceptsRequests    Boolean   @default(false) @map("accepts_requests")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([acceptsRequests, status])
  @@map("issuers")
}

model DocumentRequest {
  id                     String    @id @default(cuid())
  tenantId               String    @map("tenant_id")
  issuerId               String    @map("issuer_id")
  ownerUserId            String    @map("owner_user_id")
  documentTypeId         String    @map("document_type_id")
  documentTypeLabel      String?   @map("document_type_label")
  documentTemplateId     String?   @map("document_template_id")
  status                 String    @default("pending")
  referenceCode          String    @unique @map("reference_code")
  issuedDocumentRecordId String?   @map("issued_document_record_id")
  walletDelivered        Boolean   @default(false) @map("wallet_delivered")
  reviewedByUserId       String?   @map("reviewed_by_user_id")
  reviewedAt             DateTime? @map("reviewed_at")
  submittedAt            DateTime  @default(now()) @map("submitted_at")
  issuedAt               DateTime? @map("issued_at")
  cancelledAt            DateTime? @map("cancelled_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  issuedLink             IssuedDocument?

  @@index([tenantId, status])
  @@index([issuerId, status])
  @@index([ownerUserId, status])
  @@index([ownerUserId, issuerId, documentTypeId, status])
  @@map("document_requests")
}

model IssuedDocument {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  requestId       String   @unique @map("request_id")
  documentId      String   @map("document_id")
  issuerId        String   @map("issuer_id")
  ownerId         String   @map("owner_id")
  issuedAt        DateTime @map("issued_at")
  deliveryStatus  String   @map("delivery_status")
  linkageType     String   @map("linkage_type")
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  request DocumentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([ownerId])
  @@index([issuerId])
  @@index([documentId])
  @@index([deliveryStatus])
  @@map("issued_documents")
}

model IssuerUser {
  id          String    @id
  tenantId    String    @map("tenant_id")
  issuerId    String?   @map("issuer_id")
  userId      String?   @map("user_id")
  email       String
  role        String
  status      String    @default("active")
  invitedAt   DateTime? @map("invited_at")
  activatedAt DateTime? @map("activated_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([issuerId])
  @@index([userId])
  @@map("issuer_users")
}

model IssuerInvitation {
  id              String    @id
  tenantId        String    @map("tenant_id")
  issuerId        String?   @map("issuer_id")
  issuerUserId    String?   @map("issuer_user_id")
  email           String
  role            String
  deliveryChannel String    @map("delivery_channel")
  recipient       String
  tokenHash       String    @unique @map("token_hash")
  expiresAt       DateTime  @map("expires_at")
  usedAt          DateTime? @map("used_at")
  activatedAt     DateTime? @map("activated_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([issuerId])
  @@index([issuerUserId])
  @@index([email])
  @@map("issuer_invitations")
}

model IssuerApiClient {
  id               String   @id
  tenantId         String   @map("tenant_id")
  name             String
  clientId         String   @unique @map("client_id")
  clientSecretHash String?  @map("client_secret_hash")
  scopes           String[]
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("issuer_api_clients")
}

model IssuerApiKey {
  id          String   @id
  tenantId    String   @map("tenant_id")
  apiClientId String   @map("api_client_id")
  keyHash     String?  @map("key_hash")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([apiClientId])
  @@map("issuer_api_keys")
}

model IssuerAuthorizationCode {
  id        String    @id
  issuerId  String?   @map("issuer_id")
  tenantId  String?   @map("tenant_id")
  codeHash  String    @unique @map("code_hash")
  label     String
  status    String    @default("active")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([issuerId])
  @@index([tenantId])
  @@index([status, expiresAt])
  @@map("issuer_authorization_codes")
}

model ApiClient {
  id             String   @id @default(cuid())
  name           String
  clientId       String   @unique @map("client_id")
  clientSecret   String   @map("client_secret")
  redirectUris   String[] @map("redirect_uris")
  allowedOrigins String[] @map("allowed_origins")
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("api_clients")
}

model Consent {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  clientId  String    @map("client_id")
  scopes    String[]
  status    String    @default("approved")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([clientId])
  @@map("consents")
}

model AuthorizationCode {
  id                  String    @id @default(cuid())
  code                String    @unique
  userId              String    @map("user_id")
  clientId            String    @map("client_id")
  redirectUri         String    @map("redirect_uri")
  codeChallenge       String    @map("code_challenge")
  codeChallengeMethod String    @default("S256") @map("code_challenge_method")
  scopes              String[]
  expiresAt           DateTime  @map("expires_at")
  usedAt              DateTime? @map("used_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([clientId])
  @@index([expiresAt])
  @@map("authorization_codes")
}

model SignaturaSession {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("signatura_sessions")
}

model SignaturaAppLink {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  signaturaId String   @map("signatura_id")
  sourceApp   String   @map("source_app")
  companyCode String?  @map("company_code")
  companyName String?  @map("company_name")
  companyId   String?  @map("company_id")
  tenantId    String?  @map("tenant_id")
  accuraUserId String? @map("accura_user_id")
  role        String?
  rolePrefix  String?  @map("role_prefix")
  moduleAccess String[] @default([]) @map("accura_module_access")
  permissionSet String[] @default([]) @map("accura_permission_set")
  registrationContext Json? @map("registration_context")
  trustedDeviceStatus String? @map("trusted_device_status")
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sourceApp, companyCode, rolePrefix])
  @@index([sourceApp, companyId, rolePrefix])
  @@index([sourceApp, tenantId])
  @@index([accuraUserId])
  @@unique([userId, sourceApp, companyId, rolePrefix])
  @@unique([sourceApp, companyCode, rolePrefix, signaturaId])
  @@map("signatura_app_links")
}

model AccuraRegistrationHandoff {
  id                String    @id @default(cuid())
  tokenId           String    @unique @map("token_id")
  registrationKeyId String    @map("registration_key_id")
  companyId         String    @map("company_id")
  companyCode       String    @map("company_code")
  roleCode          String    @map("role_code")
  returnUrl         String    @map("return_url")
  status            String    @default("CLAIMED")
  userId            String?   @map("user_id")
  signaturaId       String?   @map("signatura_id")
  expiresAt         DateTime  @map("expires_at")
  claimedAt         DateTime  @default(now()) @map("claimed_at")
  completedAt       DateTime? @map("completed_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([registrationKeyId])
  @@index([companyId, roleCode])
  @@index([status])
  @@index([expiresAt])
  @@map("accura_registration_handoffs")
}

model AuditAnchor {
  id         String    @id @default(cuid())
  sourceApp  String    @map("source_app")
  recordType String    @map("record_type")
  recordId   String    @map("record_id")
  hash       String
  status     String    @default("pending")
  createdAt  DateTime  @default(now()) @map("created_at")
  anchoredAt DateTime? @map("anchored_at")

  @@index([sourceApp])
  @@index([recordType, recordId])
  @@index([status])
  @@map("audit_anchors")
}

model DocumentType {
  id          String   @id
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("document_types")
}

model DocumentTemplate {
  id               String                  @id
  tenantId         String                  @map("tenant_id")
  documentTypeId   String?                 @map("document_type_id")
  name             String
  schema           Json?
  fields           Json?
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")
  issuerId         String?                 @map("issuer_id")
  documentType     String?                 @map("document_type")
  version          Int                     @default(1)
  status           String                  @default("draft")
  originalFileUrl  String?                 @map("original_file_url")
  previewImageUrl  String?                 @map("preview_image_url")
  createdBy        String?                 @map("created_by")
  publishedBy      String?                 @map("published_by")
  publishedAt      DateTime?               @map("published_at")
  sourceTemplateId String?                 @map("source_template_id")
  auditLogs        TemplateAuditLog[]
  extractionLogs   TemplateExtractionLog[]
  templateFields   DocumentTemplateField[]
  versions         TemplateVersion[]

  @@index([tenantId])
  @@index([issuerId])
  @@index([documentTypeId])
  @@index([status])
  @@index([sourceTemplateId])
  @@map("document_templates")
}

model DocumentTemplateField {
  id             String           @id
  templateId     String           @map("template_id")
  fieldLabel     String           @map("field_label")
  fieldKey       String           @map("field_key")
  fieldType      String           @map("field_type")
  required       Boolean          @default(false)
  encrypted      Boolean          @default(false)
  publicVisible  Boolean          @default(false) @map("public_visible")
  searchable     Boolean          @default(false)
  validationRule String?          @map("validation_rule")
  defaultValue   String?          @map("default_value")
  optionsJson    Json?            @map("options_json")
  xPosition      Float            @default(0) @map("x_position")
  yPosition      Float            @default(0) @map("y_position")
  width          Float            @default(20)
  height         Float            @default(8)
  pageNumber     Int              @default(1) @map("page_number")
  sortOrder      Int              @default(0) @map("sort_order")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  template       DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([fieldKey])
  @@map("template_fields")
}

model TemplateVersion {
  id           String           @id
  templateId   String           @map("template_id")
  version      Int
  status       String
  schemaJson   Json?            @map("schema_json")
  fieldsJson   Json?            @map("fields_json")
  templateHash String?          @map("template_hash")
  createdBy    String?          @map("created_by")
  createdAt    DateTime         @default(now()) @map("created_at")
  template     DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([version])
  @@map("template_versions")
}

model TemplateExtractionLog {
  id                String           @id
  templateId        String           @map("template_id")
  extractionStatus  String           @map("extraction_status")
  ocrProvider       String?          @map("ocr_provider")
  rawOcrJson        Json?            @map("raw_ocr_json")
  aiSuggestionsJson Json?            @map("ai_suggestions_json")
  errorMessage      String?          @map("error_message")
  createdAt         DateTime         @default(now()) @map("created_at")
  template          DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([extractionStatus])
  @@map("template_extraction_logs")
}

model TemplateAuditLog {
  id           String           @id
  templateId   String           @map("template_id")
  userId       String?          @map("user_id")
  action       String
  oldValueJson Json?            @map("old_value_json")
  newValueJson Json?            @map("new_value_json")
  createdAt    DateTime         @default(now()) @map("created_at")
  template     DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([userId])
  @@index([action])
  @@map("template_audit_logs")
}

model DocumentRecord {
  id                 String        @id
  tenantId           String        @map("tenant_id")
  documentTemplateId String?       @map("document_template_id")
  externalId         String        @map("external_id")
  recipientName      String        @map("recipient_name")
  issuedAt           DateTime      @map("issued_at")
  hash               String
  status             String        @default("valid")
  verificationToken  String        @unique @map("verification_token")
  qrToken            String        @unique @map("qr_token")
  metadata           Json?
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  anchorBatchId      String?       @map("anchor_batch_id")
  anchorStatus       String        @default("pending") @map("anchor_status")
  documentHash       String?       @map("document_hash")
  issuerId           String?       @map("issuer_id")
  ownerUserId        String?       @map("owner_user_id")
  documentRequestId  String?       @unique @map("document_request_id")
  documentTypeLabel  String?       @map("document_type_label")
  anchorPool         AnchorPool[]
  merkleProofs       MerkleProof[]

  @@index([tenantId])
  @@index([issuerId])
  @@index([ownerUserId])
  @@index([documentTemplateId])
  @@index([externalId])
  @@index([anchorStatus])
  @@index([anchorBatchId])
  @@map("document_records")
}

model AnchorPool {
  id           String         @id
  documentId   String         @map("document_id")
  documentHash String         @map("document_hash")
  status       String         @default("pending")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  document     DocumentRecord @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([documentHash])
  @@index([status])
  @@map("anchor_pool")
}

model MerkleBatch {
  id             String        @id
  merkleRoot     String        @map("merkle_root")
  batchSize      Int           @map("batch_size")
  status         String        @default("created")
  publishMethod  String        @map("publish_method")
  chain          String?
  transactionId  String?       @map("transaction_id")
  blockNumber    String?       @map("block_number")
  timestampProof String?       @map("timestamp_proof")
  errorMessage   String?       @map("error_message")
  publishedAt    DateTime?     @map("published_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  proofs         MerkleProof[]

  @@index([status])
  @@index([publishMethod])
  @@index([transactionId])
  @@map("merkle_batches")
}

model MerkleProof {
  id         String         @id
  documentId String         @map("document_id")
  batchId    String         @map("batch_id")
  leafHash   String         @map("leaf_hash")
  proofPath  Json           @map("proof_path")
  proofIndex Int            @map("proof_index")
  createdAt  DateTime       @default(now()) @map("created_at")
  batch      MerkleBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  document   DocumentRecord @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([batchId])
  @@index([leafHash])
  @@map("merkle_proofs")
}

