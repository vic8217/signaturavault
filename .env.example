DATABASE_URL="postgresql://postgres:postgres@localhost:5432/signatura?schema=public"
SESSION_SECRET="replace-with-a-long-random-session-secret"
RECOVERY_CODE_SECRET="replace-with-a-long-random-recovery-code-secret"
ACTIVATION_TOKEN_SECRET="replace-with-a-long-random-activation-token-secret"
ADMIN_PROVISIONING_SECRET="replace-with-a-long-random-admin-provisioning-secret"

# Optional local OCR tuning. The pipeline never sends documents to cloud OCR.
TESSERACT_LANG="eng"
TESSERACT_PSM="6"
TESSERACT_LANG_PATH="./data/tessdata"
TESSERACT_CACHE_PATH="./data/tessdata-cache"
OCR_MAX_PDF_PAGES="3"
TEMPLATE_UPLOAD_MAX_MB="50"
NEXT_PUBLIC_TEMPLATE_UPLOAD_MAX_MB="50"
TEMPLATE_UPLOAD_PROXY_MAX_BODY_SIZE="50mb"

# Public URL phones can reach (required for QR login when desktop uses localhost).
# Example: https://your-subdomain.ngrok-free.dev
SIGNATURA_PUBLIC_URL=""
NEXT_PUBLIC_SIGNATURA_PUBLIC_URL=""
# Phone-reachable ACCURA origin used when a handoff contains localhost.
ACCURA_ORIGIN="http://192.168.68.139:3001"
# Mirror ACCURA_ORIGIN so browser-side return URL validation works after trusted-device approval.
NEXT_PUBLIC_ACCURA_ORIGIN="http://192.168.68.139:3001"
# Optional ACCURA challenge approval endpoint for app-approval QR callbacks.
# You may set the full API URL or just the ACCURA origin; the path
# /api/signatura/challenge-approve is appended automatically when missing.
# Do NOT point this at /api/auth/signatura/qr/approve (that is QR login only).
ACCURA_CHALLENGE_APPROVE_URL="https://accura-sandbox.example.com/api/signatura/challenge-approve"
# Optional auth for the ACCURA callback endpoint when nginx/basic auth protects sandbox.
# Use the same username/password you use to open accura-sandbox in a browser.
# Prefer allowlisting /api/signatura/challenge-approve at nginx instead of requiring auth.
ACCURA_CHALLENGE_APPROVE_AUTH_HEADER=""
ACCURA_CHALLENGE_APPROVE_BEARER_TOKEN=""
ACCURA_CHALLENGE_APPROVE_BASIC_USER=""
ACCURA_CHALLENGE_APPROVE_BASIC_PASSWORD=""

# ACCURA QR login (Signatura wallet → Scan Login QR). Use /api/signatura/qr-login/* .
# Legacy /api/auth/signatura/qr/* is rewritten automatically but should not be used.
ACCURA_QR_CHALLENGE_URL="https://accura-sandbox.example.com/api/signatura/qr-login/challenge"
ACCURA_QR_APPROVE_URL="https://accura-sandbox.example.com/api/signatura/qr-login/approve"
# Optional HTTP auth for ACCURA sandbox nginx in front of QR endpoints.
# Prefer nginx auth_basic off for /api/signatura/qr-login/*; otherwise set
# basic user/password or an explicit Authorization header.
ACCURA_QR_AUTH_HEADER=""
ACCURA_QR_BASIC_USER=""
ACCURA_QR_BASIC_PASSWORD=""
ACCURA_QR_BEARER_TOKEN=""
# On sandbox nginx, allowlist these ACCURA paths (auth_basic off):
# /api/signatura/qr-login/challenge, /api/signatura/qr-login/approve
# On Signatura sandbox nginx, allowlist ACCURA server introspection (auth_basic off):
# /api/signatura/accura/qr-login/introspect
SIGNATURA_QR_APPROVAL_SECRET=""
# header sends X-Signatura-Approval-Secret, bearer sends Authorization: Bearer,
# both sends both and uses Bearer instead of Basic Authorization.
SIGNATURA_QR_APPROVAL_SECRET_MODE="header"
ACCURA_CLIENT_ID="accura"
ACCURA_CLIENT_SECRET=""
PADDLEOCR_DET_MODEL_PATH=""
PADDLEOCR_REC_MODEL_PATH=""
PADDLEOCR_DICT_PATH=""
