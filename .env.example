DATABASE_URL="postgresql://postgres:postgres@localhost:5432/signatura?schema=public"
SESSION_SECRET="replace-with-a-long-random-session-secret"
RECOVERY_CODE_SECRET="replace-with-a-long-random-recovery-code-secret"
ACTIVATION_TOKEN_SECRET="replace-with-a-long-random-activation-token-secret"
ADMIN_PROVISIONING_SECRET="replace-with-a-long-random-admin-provisioning-secret"

# Optional local OCR tuning. The pipeline never sends documents to cloud OCR.
TESSERACT_LANG="eng"
TESSERACT_PSM="6"
TESSERACT_LANG_PATH="./data/tessdata"
TESSERACT_CACHE_PATH="./data/tessdata-cache"
OCR_MAX_PDF_PAGES="3"
TEMPLATE_UPLOAD_MAX_MB="50"
NEXT_PUBLIC_TEMPLATE_UPLOAD_MAX_MB="50"
TEMPLATE_UPLOAD_PROXY_MAX_BODY_SIZE="50mb"

# Public URL phones can reach (required for QR login when desktop uses localhost).
# Example: https://your-subdomain.ngrok-free.dev
SIGNATURA_PUBLIC_URL=""
NEXT_PUBLIC_SIGNATURA_PUBLIC_URL=""
# Phone-reachable ACCURA origin used when a handoff contains localhost.
ACCURA_ORIGIN="http://192.168.68.139:3001"
# Mirror ACCURA_ORIGIN so browser-side return URL validation works after trusted-device approval.
NEXT_PUBLIC_ACCURA_ORIGIN="http://192.168.68.139:3001"
# Optional ACCURA challenge approval endpoint for app-approval QR callbacks.
# You may set the full API URL or just the ACCURA origin; the path
# /api/signatura/challenge-approve is appended automatically when missing.
ACCURA_CHALLENGE_APPROVE_URL="https://accura-sandbox.example.com/api/signatura/challenge-approve"

# ACCURA QR login approval service. These are server-side URLs and credentials.
ACCURA_QR_CHALLENGE_URL=""
ACCURA_QR_APPROVE_URL=""
ACCURA_CLIENT_ID="accura"
ACCURA_CLIENT_SECRET=""
PADDLEOCR_DET_MODEL_PATH=""
PADDLEOCR_REC_MODEL_PATH=""
PADDLEOCR_DICT_PATH=""
